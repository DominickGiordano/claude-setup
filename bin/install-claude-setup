#!/usr/bin/env bash
# install-claude-setup
# Installs global Claude Code config from the claude-setup repo to ~/.claude/
# Safe by default — never overwrites existing files unless --force is passed.
# With --force, creates timestamped backups before overwriting.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
SOURCE_DIR="$REPO_DIR/global"
CLAUDE_DIR="$HOME/.claude"
FORCE=false
BACKUP_DIR="$CLAUDE_DIR/.backups/$(date +%Y%m%d-%H%M%S)"

usage() {
  echo "Usage: install-claude-setup [--force]"
  echo ""
  echo "Installs global Claude Code config to ~/.claude/"
  echo ""
  echo "Options:"
  echo "  --force    Overwrite existing files (creates backups first)"
  echo "  --dry-run  Show what would be done without doing it"
  echo "  --help     Show this help"
}

DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=true; shift ;;
    --dry-run) DRY_RUN=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 1 ;;
  esac
done

log() { echo "  $1"; }

backup_file() {
  local file="$1"
  local base_dir="${2:-$CLAUDE_DIR}"
  local bak_dir="${3:-$BACKUP_DIR}"
  if [[ -f "$file" ]]; then
    local rel="${file#$base_dir/}"
    local backup_path="$bak_dir/$rel"
    mkdir -p "$(dirname "$backup_path")"
    cp "$file" "$backup_path"
  fi
}

copy_file() {
  local src="$1"
  local dst="$2"
  local base_dir="${3:-$CLAUDE_DIR}"
  local bak_dir="${4:-$BACKUP_DIR}"

  if [[ "$DRY_RUN" == "true" ]]; then
    if [[ -f "$dst" ]] && [[ "$FORCE" == "false" ]]; then
      log "SKIP (exists): $dst"
    elif [[ -f "$dst" ]]; then
      log "WOULD OVERWRITE (backup + copy): $dst"
    else
      log "WOULD CREATE: $dst"
    fi
    return
  fi

  if [[ -f "$dst" ]] && [[ "$FORCE" == "false" ]]; then
    log "SKIP (exists): $dst"
  elif [[ -f "$dst" ]]; then
    backup_file "$dst" "$base_dir" "$bak_dir"
    cp "$src" "$dst"
    log "UPDATED (backed up): $dst"
  else
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    log "CREATED: $dst"
  fi
}

echo "install-claude-setup"
echo "  Source: $SOURCE_DIR"
echo "  Target: $CLAUDE_DIR"
[[ "$FORCE" == "true" ]] && echo "  Mode: FORCE (backups to $BACKUP_DIR)"
[[ "$DRY_RUN" == "true" ]] && echo "  Mode: DRY RUN"
echo ""

# Check hook runtimes
if [[ -f "$SOURCE_DIR/hooks/check-runtime.sh" ]] && [[ "$DRY_RUN" == "false" ]]; then
  bash "$SOURCE_DIR/hooks/check-runtime.sh" 2>/dev/null || true
fi

# Create directories
if [[ "$DRY_RUN" == "false" ]]; then
  mkdir -p "$CLAUDE_DIR"/{agents,skills,output-styles,hooks}
fi

# CLAUDE.md
copy_file "$SOURCE_DIR/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"

# settings.json
if [[ -f "$CLAUDE_DIR/settings.json" ]] && [[ "$FORCE" == "false" ]]; then
  log "SKIP (exists): $CLAUDE_DIR/settings.json — merge manually if needed"
else
  copy_file "$SOURCE_DIR/settings.json" "$CLAUDE_DIR/settings.json"
fi

# Agents
for f in "$SOURCE_DIR"/agents/*.md; do
  [[ -f "$f" ]] || continue
  copy_file "$f" "$CLAUDE_DIR/agents/$(basename "$f")"
done

# Skills — installed as ~/.claude/skills/<name>/SKILL.md (directory structure)
for f in "$SOURCE_DIR"/skills/*.md; do
  [[ -f "$f" ]] || continue
  skill_name="$(basename "$f" .md)"
  [[ "$DRY_RUN" == "false" ]] && mkdir -p "$CLAUDE_DIR/skills/$skill_name"
  copy_file "$f" "$CLAUDE_DIR/skills/$skill_name/SKILL.md"
done

# Commands — installed as skills with directory structure
for f in "$SOURCE_DIR"/commands/*.md; do
  [[ -f "$f" ]] || continue
  skill_name="$(basename "$f" .md)"
  [[ "$DRY_RUN" == "false" ]] && mkdir -p "$CLAUDE_DIR/skills/$skill_name"
  copy_file "$f" "$CLAUDE_DIR/skills/$skill_name/SKILL.md"
done

# Hooks
for f in "$SOURCE_DIR"/hooks/*.js; do
  [[ -f "$f" ]] || continue
  copy_file "$f" "$CLAUDE_DIR/hooks/$(basename "$f")"
  [[ "$DRY_RUN" == "false" ]] && chmod +x "$CLAUDE_DIR/hooks/$(basename "$f")"
done

# --- Sync template files to registered projects ---
PROJECTS_FILE="$CLAUDE_DIR/.projects"
TEMPLATE_DIR="$REPO_DIR/project-template"

if [[ -f "$PROJECTS_FILE" ]] && [[ "$FORCE" == "true" ]]; then
  echo ""
  echo "Syncing project template files to registered projects..."
  echo ""

  while IFS= read -r project_dir || [[ -n "$project_dir" ]]; do
    [[ -z "$project_dir" ]] && continue
    [[ "$project_dir" == \#* ]] && continue

    if [[ ! -d "$project_dir/.claude" ]]; then
      log "SKIP (not found): $project_dir"
      continue
    fi

    proj_backup="$project_dir/.claude/.backups/$(date +%Y%m%d-%H%M%S)"
    echo "  Project: $(basename "$project_dir") ($project_dir)"

    # Ensure directories exist
    mkdir -p "$project_dir"/.claude/prompts
    mkdir -p "$project_dir"/.github/workflows
    mkdir -p "$project_dir"/docs/{reference,workflows}
    mkdir -p "$project_dir"/.claude/rules

    # CI workflow + triage prompt — always sync
    for f in "$TEMPLATE_DIR"/.github/workflows/*.yml; do
      [[ -f "$f" ]] || continue
      copy_file "$f" "$project_dir/.github/workflows/$(basename "$f")" "$project_dir" "$proj_backup"
    done
    for f in "$TEMPLATE_DIR"/.claude/prompts/*.md; do
      [[ -f "$f" ]] || continue
      copy_file "$f" "$project_dir/.claude/prompts/$(basename "$f")" "$project_dir" "$proj_backup"
    done

    # Reference docs — always sync (these are system docs, not project-specific)
    for f in "$TEMPLATE_DIR"/docs/reference/*.md; do
      [[ -f "$f" ]] || continue
      copy_file "$f" "$project_dir/docs/reference/$(basename "$f")" "$project_dir" "$proj_backup"
    done

    # Workflow docs — always sync
    for f in "$TEMPLATE_DIR"/docs/workflows/*.md; do
      [[ -f "$f" ]] || continue
      copy_file "$f" "$project_dir/docs/workflows/$(basename "$f")" "$project_dir" "$proj_backup"
    done

    # Domain rules (backend, frontend, infra, ios) — always sync
    # SKIP org.md — that's project/org-specific
    for f in "$TEMPLATE_DIR"/.claude/rules/*.md; do
      [[ -f "$f" ]] || continue
      [[ "$(basename "$f")" == "org.md" ]] && continue
      copy_file "$f" "$project_dir/.claude/rules/$(basename "$f")" "$project_dir" "$proj_backup"
    done

    echo ""
  done < "$PROJECTS_FILE"
elif [[ -f "$PROJECTS_FILE" ]] && [[ "$FORCE" == "false" ]]; then
  echo ""
  echo "Registered projects found in ~/.claude/.projects"
  echo "Run with --force to sync template files to all projects."
fi

echo ""
if [[ "$DRY_RUN" == "true" ]]; then
  echo "Dry run complete. No files were changed."
else
  echo "Global config installed to $CLAUDE_DIR"
  [[ "$FORCE" == "true" ]] && echo "Backups saved to $BACKUP_DIR"
fi
