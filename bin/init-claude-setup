#!/usr/bin/env bash
# init-claude-setup
# Scaffolds .claude/ and docs/ in the current project directory.
# Run from your project root.
# Safe by default — never overwrites existing files.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
TEMPLATE_DIR="$REPO_DIR/project-template"
PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

usage() {
  echo "Usage: init-claude-setup [--force]"
  echo ""
  echo "Scaffolds .claude/ and docs/ for Claude Code in the current project."
  echo ""
  echo "Options:"
  echo "  --force    Overwrite existing files (creates backups first)"
  echo "  --dry-run  Show what would be done without doing it"
  echo "  --help     Show this help"
}

FORCE=false
DRY_RUN=false
BACKUP_DIR="$PROJECT_DIR/.claude/.backups/$(date +%Y%m%d-%H%M%S)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=true; shift ;;
    --dry-run) DRY_RUN=true; shift ;;
    --help) usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 1 ;;
  esac
done

log() { echo "  $1"; }

backup_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    local rel="${file#$PROJECT_DIR/}"
    local backup_path="$BACKUP_DIR/$rel"
    mkdir -p "$(dirname "$backup_path")"
    cp "$file" "$backup_path"
  fi
}

copy_if_missing() {
  local src="$1"
  local dst="$2"

  if [[ "$DRY_RUN" == "true" ]]; then
    if [[ -f "$dst" ]] && [[ "$FORCE" == "false" ]]; then
      log "SKIP (exists): $dst"
    elif [[ -f "$dst" ]]; then
      log "WOULD OVERWRITE (backup + copy): $dst"
    else
      log "WOULD CREATE: $dst"
    fi
    return
  fi

  if [[ -f "$dst" ]] && [[ "$FORCE" == "false" ]]; then
    log "SKIP (exists): $dst"
  elif [[ -f "$dst" ]]; then
    backup_file "$dst"
    cp "$src" "$dst"
    log "UPDATED (backed up): $dst"
  else
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
    log "CREATED: $dst"
  fi
}

echo "init-claude-setup"
echo "  Project: $PROJECT_NAME"
echo "  Target:  $PROJECT_DIR"
[[ "$FORCE" == "true" ]] && echo "  Mode: FORCE (backups to $BACKUP_DIR)"
[[ "$DRY_RUN" == "true" ]] && echo "  Mode: DRY RUN"
echo ""

# Create dirs
if [[ "$DRY_RUN" == "false" ]]; then
  mkdir -p "$PROJECT_DIR"/.claude/{agents,skills,commands,memory}
  mkdir -p "$PROJECT_DIR"/docs/{workflows,plans,spikes,solutions}
fi

# Copy template files
copy_if_missing "$TEMPLATE_DIR/.claude/CLAUDE.md"              "$PROJECT_DIR/.claude/CLAUDE.md"
copy_if_missing "$TEMPLATE_DIR/.claude/settings.json"          "$PROJECT_DIR/.claude/settings.json"
copy_if_missing "$TEMPLATE_DIR/.claude/memory/session-log.md"  "$PROJECT_DIR/.claude/memory/session-log.md"
copy_if_missing "$TEMPLATE_DIR/docs/architecture.md"           "$PROJECT_DIR/docs/architecture.md"

# Copy workflow docs if they exist in the template
for f in "$TEMPLATE_DIR"/docs/workflows/*.md; do
  [[ -f "$f" ]] || continue
  copy_if_missing "$f" "$PROJECT_DIR/docs/workflows/$(basename "$f")"
done

# Add .claude/memory and .claude/.backups to .gitignore
GITIGNORE="$PROJECT_DIR/.gitignore"
if [[ "$DRY_RUN" == "false" ]]; then
  if [[ -f "$GITIGNORE" ]]; then
    ADDITIONS=""
    if ! grep -q ".claude/memory" "$GITIGNORE" 2>/dev/null; then
      ADDITIONS+="\n# Claude Code session memory (personal, not shared)\n.claude/memory/"
    fi
    if ! grep -q ".claude/.backups" "$GITIGNORE" 2>/dev/null; then
      ADDITIONS+="\n# Claude setup backups\n.claude/.backups/"
    fi
    if [[ -n "$ADDITIONS" ]]; then
      echo -e "$ADDITIONS" >> "$GITIGNORE"
      log "Updated .gitignore"
    fi
  fi
fi

echo ""
if [[ "$DRY_RUN" == "true" ]]; then
  echo "Dry run complete. No files were changed."
else
  echo "Project initialized."
  echo ""
  echo "Next:"
  echo "  1. Edit .claude/CLAUDE.md — fill in stack, commands, key paths"
  echo "  2. Edit docs/architecture.md — document the system design"
  echo "  3. Run Claude Code: claude"
  echo "  4. Type /catchup to load context"
fi
